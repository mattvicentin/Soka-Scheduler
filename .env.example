# =============================================================================
# Soka Academic Scheduling - Environment Variables
# =============================================================================
# Copy to .env and fill in values.
# For local dev: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Railway, local, or any Postgres host).
# Local: postgresql://user:password@localhost:5432/soka_scheduling
DATABASE_URL="postgresql://user:password@localhost:5432/soka_scheduling"

# -----------------------------------------------------------------------------
# Auth (required for production)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=""

# -----------------------------------------------------------------------------
# Admin credentials (required for seed to create admin)
# -----------------------------------------------------------------------------
# Used for initial login. Admin account created/updated on `npm run db:seed`.
ADMIN_EMAIL="admin@soka.edu"
ADMIN_PASSWORD=""

# -----------------------------------------------------------------------------
# App URL (required for invitation links)
# -----------------------------------------------------------------------------
# Local: http://localhost:3000
# Staging: https://your-staging-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# Modes:
#   - Omit or set "console": invitations/verification codes logged to console (default for dev)
#   - Set RESEND_API_KEY: real email via Resend (see docs/DEPLOYMENT.md)
# If RESEND_API_KEY is set, Resend is used automatically even without EMAIL_PROVIDER.
# Never commit real keys; rotate any key that was exposed.
EMAIL_PROVIDER="console"
RESEND_API_KEY=""
# Must match a sender/domain verified in Resend (production).
EMAIL_FROM="noreply@soka.edu"

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
NODE_ENV="development"
