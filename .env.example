# =============================================================================
# Soka Academic Scheduling - Environment Variables
# =============================================================================
# Copy to .env and fill in values.
# For local dev: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Railway, local, or any Postgres host).
# Local: postgresql://user:password@localhost:5432/soka_scheduling
DATABASE_URL="postgresql://user:password@localhost:5432/soka_scheduling"

# -----------------------------------------------------------------------------
# Auth (required for production)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=""

# -----------------------------------------------------------------------------
# Admin credentials (required for seed to create admin)
# -----------------------------------------------------------------------------
# Used for initial login. Admin account created/updated on `npm run db:seed`.
ADMIN_EMAIL="admin@soka.edu"
ADMIN_PASSWORD=""

# -----------------------------------------------------------------------------
# App URL (required for invitation links)
# -----------------------------------------------------------------------------
# Local: http://localhost:3000
# Staging: https://your-staging-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# EMAIL_PROVIDER: console | emailjs | resend
#   - console: log only (default when no provider keys are set)
#   - emailjs: PoC without DNS — see docs/DEPLOYMENT.md (template params: to_email, email_subject, email_body, email_html)
#   - resend: production — domain verification in Resend; set RESEND_API_KEY + EMAIL_FROM
# If EMAIL_PROVIDER is unset: Resend is chosen when RESEND_API_KEY is set; else EmailJS when all EMAILJS_* are set.
# Never commit real keys; rotate any key that was exposed.
EMAIL_PROVIDER="console"

# Resend (production)
RESEND_API_KEY=""
EMAIL_FROM="noreply@soka.edu"

# EmailJS (PoC — Email dashboard email service + template)
EMAILJS_SERVICE_ID=""
EMAILJS_TEMPLATE_ID=""
EMAILJS_PUBLIC_KEY=""
EMAILJS_PRIVATE_KEY=""

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
NODE_ENV="development"
