# =============================================================================
# Soka Academic Scheduling - Environment Variables
# =============================================================================
# Copy to .env and fill in values.
# For local dev: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Local: postgresql://user:password@localhost:5432/soka_scheduling
# Supabase (Vercel): transaction pooler for the app — port 6543, include ?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/soka_scheduling"
# Used by prisma migrate (DDL). Supabase: session pooler on port 5432, or direct db.<project-ref>.supabase.co:5432
# Local dev: copy the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/soka_scheduling"

# -----------------------------------------------------------------------------
# Auth (required for production)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=""

# -----------------------------------------------------------------------------
# Admin credentials (required for seed to create admin)
# -----------------------------------------------------------------------------
# Used for initial login. Admin account created/updated on `npm run db:seed`.
ADMIN_EMAIL="admin@soka.edu"
ADMIN_PASSWORD=""

# -----------------------------------------------------------------------------
# App URL (required for invitation links)
# -----------------------------------------------------------------------------
# Local: http://localhost:3000
# Staging: https://your-staging-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# Modes:
#   - Omit or set "console": invitations/verification codes logged to console (default for dev)
#   - Set "resend" + RESEND_API_KEY: real email via Resend
# If RESEND_API_KEY is set, Resend mode is used automatically even without EMAIL_PROVIDER.
EMAIL_PROVIDER="console"
RESEND_API_KEY=""
EMAIL_FROM="noreply@soka.edu"

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
NODE_ENV="development"
